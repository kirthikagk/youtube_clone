  100% { transform: translateY(-16px); }
}

@keyframes xuttrn-B {=20
  0% { transform: translateY(-17px); }
  100% { transform: translateY(17px); }
}

@keyframes xuza879-B {=20
  0% { transform: scale(0); }
  100% { transform: scale(1); }
}

@keyframes xv3vjy1-B {=20
  0% { opacity: 0.7; }
  100% { opacity: 1; }
}

@keyframes xva7eij-B {=20
  0% { opacity: 1; transform: translateY(0px); }
  100% { opacity: 0; transform: translateY(20px); }
}

@keyframes xvfaeil-B {=20
  0% { opacity: var(--glimmer-opacity-min); }
  100% { opacity: var(--glimmer-opacity-max); }
}

@keyframes xvowxyv-B {=20
  0% { opacity: 1; transform: scale(1); }
  100% { opacity: 0; transform: scale(1.05); display: none; }
}

@keyframes xwetn48-B {=20
  0% { top: 9px; left: 6px; width: 0px; height: 0px; }
  100% { top: 1px; left: 4px; width: 4px; height: 8px; }
}

@keyframes xwqjvqw-B {=20
  0% { transform: translateY(0px); }
  100% { transform: translateY(-17px); }
}

@keyframes xwrokor-B {=20
  0% { transform: scale(0.01); }
  25% { transform: scaleX(0.21); animation-timing-function: cubic-bezier(0.=
83, 0, 0.17, 1); }
  62% { transform: scaleX(1.05); animation-timing-function: cubic-bezier(0.=
83, 0, 0.17, 1); }
  100% { transform: scaleX(1); }
}

@keyframes xx7n0n2-B {=20
  0% { transform: scale3d(0.8, 0.8, 1); opacity: 0; }
  100% { transform: scaleZ(1); opacity: 1; }
}

@keyframes xxodl7o-B {=20
  0% { opacity: 0.5; }
  50% { opacity: 1; }
  100% { opacity: 0.5; }
}

@keyframes xyg6gxy-B {=20
  0% { opacity: 0.265; transform: scale(0.8); }
  5% { opacity: 0.25; }
  50% { transform: scale(1); }
  55% { opacity: 1; }
  100% { opacity: 0.265; transform: scale(0.8); }
}

@keyframes xyllbq6-B {=20
  0% { transform: rotate(-90deg); }
  25% { transform: rotate(90deg); }
  50% { transform: rotate(270deg); }
  75% { transform: rotate(450deg); }
  100% { transform: rotate(990deg); }
}

@keyframes xyswhzy-B {=20
  0% { transform: scale(1); }
  100% { transform: scale(1.15); }
}

@keyframes xz9a51c-B {=20
  0% { stroke-dashoffset: 13.8px; transform: rotate(-90deg); }
  25% { stroke-dashoffset: 62.2px; transform: rotate(162deg); }
  50% { stroke-dashoffset: 31.1px; transform: rotate(72deg); }
  75% { stroke-dashoffset: 62.2px; transform: rotate(162deg); }
  100% { stroke-dashoffset: 13.8px; transform: rotate(-90deg); }
}

